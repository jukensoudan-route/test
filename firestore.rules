rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ログイン済みのコーチだけが共有データを閲覧・編集できます。
    match /teams/{teamId}/state/{documentId} {
      allow read, write: if request.auth != null;
    }

    // その他のデータは拒否します。
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
